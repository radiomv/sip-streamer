#
# baresip configuration -- listener (records received audio)
#

# Core
poll_method		epoll

# SIP
#sip_cafile		/etc/ssl/certs/ca-certificates.crt
sip_verify_server	no

# Call
call_local_timeout	120
call_max_calls		1

# Audio - play received audio to a file, send silence
audio_player		aufile,/tmp/listen_pipe.wav
audio_source		aufile,/tmp/silence.wav
ausrc_srate		48000
auplay_srate		48000
audio_level		no
ausrc_format		s16
auplay_format		s16
auenc_format		s16
audec_format		s16
audio_buffer		20-160

# AVT
rtp_tos			184
rtcp_mux		no
jitter_buffer_type	fixed
jitter_buffer_delay	5-10

#------------------------------------------------------------------------------
# Modules

module_path		/usr/lib/baresip/modules

# UI
module			stdio.so
#module			cons.so

# Audio codecs (in order)
module			g722.so
module			opus.so
module			g711.so

# Audio filters
#module			vumeter.so

# Audio drivers
module			aufile.so

# Compatibility
module			uuid.so

# Media NAT
module			stun.so
module			turn.so
module			ice.so

#------------------------------------------------------------------------------
# Application Modules

module_app		account.so
module_app		contact.so
module_app		debug_cmd.so
module_app		menu.so

#------------------------------------------------------------------------------
# Module parameters

cons_listen		0.0.0.0:5555

# Opus
opus_bitrate		64000
opus_inbandfec		yes
opus_complexity		10
